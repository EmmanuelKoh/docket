# Printer network settings
PRINTER_IP=
PRINTER_PORT=9100

# Print width in pixels (576 for 80mm, 384 for 58mm)
PRINT_WIDTH=576

# Directory containing DejaVu TTF font files
FONT_DIR=

# Storage driver: json (local files in data/) or redis (Upstash + Vercel Blob)
STORE_DRIVER=json

# Owner stamped on every stored record (multi-user-ready; one value for now)
OWNER_ID=default

# Shared secret the printer agent sends to /next, /ack, /nack as
# "Authorization: Bearer <token>". Defaults to dev-token for local dev —
# set a long random value anywhere the server is reachable from outside.
DEVICE_TOKEN=

# Dashboard door: the password typed at /login, and the secret that signs
# the stateless session cookie. Both required for the dashboard to work.
DASHBOARD_PASSWORD=
SESSION_SECRET=

# User accounts (Better Auth). Postgres connection: the Neon URL in
# production, a Neon dev-branch URL locally — or leave unset and local dev
# uses PGlite, an embedded Postgres in data/pg (no cloud account needed).
# BETTER_AUTH_SECRET signs account session cookies (falls back to
# SESSION_SECRET); BETTER_AUTH_URL pins the canonical origin in production
# (e.g. https://docket.example.com), unset locally.
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# Seconds an unacked inflight job holds its lease before returning to the
# queue (redis driver only)
LEASE_SECONDS=120

# Seconds between /tick POSTs from agent/heartbeat.js (each tick runs the
# registered plugins that are enabled and due)
HEARTBEAT_SECONDS=30

# Upstash Redis connection (required when STORE_DRIVER=redis).
# From the Upstash console, or auto-set by the Vercel Marketplace integration
# (which may name them KV_REST_API_URL / KV_REST_API_TOKEN — both pairs work).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob read-write token (required when STORE_DRIVER=redis).
# Auto-set on Vercel deployments; copy from the Vercel dashboard for local use.
BLOB_READ_WRITE_TOKEN=

# Message ingestion (/ingest) — SMS forwarded from a phone, classified by
# Gemini, printed as task receipts. INGEST_TOKEN is the shared secret the
# forwarder app sends (Bearer header or ?token=); the endpoint is off until
# it's set. GEMINI_API_KEY from Google AI Studio (aistudio.google.com).
INGEST_TOKEN=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
INGEST_TIMEZONE=America/New_York

