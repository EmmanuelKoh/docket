# Printer network settings
PRINTER_IP=
PRINTER_PORT=9100

# Print width in pixels (576 for 80mm, 384 for 58mm)
PRINT_WIDTH=576

# Directory containing DejaVu TTF font files
FONT_DIR=

# Storage driver: json (local files in data/) or redis (Upstash + Vercel Blob)
STORE_DRIVER=json

# Owner stamped on every stored record (multi-user-ready; one value for now)
OWNER_ID=default

# Shared secret the printer agent sends to /next, /ack, /nack as
# "Authorization: Bearer <token>". Defaults to dev-token for local dev —
# set a long random value anywhere the server is reachable from outside.
DEVICE_TOKEN=

# Seconds an unacked inflight job holds its lease before returning to the
# queue (redis driver only)
LEASE_SECONDS=120

# Upstash Redis connection (required when STORE_DRIVER=redis).
# From the Upstash console, or auto-set by the Vercel Marketplace integration
# (which may name them KV_REST_API_URL / KV_REST_API_TOKEN — both pairs work).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob read-write token (required when STORE_DRIVER=redis).
# Auto-set on Vercel deployments; copy from the Vercel dashboard for local use.
BLOB_READ_WRITE_TOKEN=
