{
  "functions": {
    "api/tick.js": { "maxDuration": 60 },
    "api/jobs.js": { "maxDuration": 60 },
    "api/dashboard.js": {
      "maxDuration": 60,
      "includeFiles": "views/**"
    }
  },
  "rewrites": [
    { "source": "/preview", "destination": "/api/preview" },
    { "source": "/templates", "destination": "/api/templates" },
    { "source": "/jobs", "destination": "/api/jobs" },
    { "source": "/next", "destination": "/api/next" },
    { "source": "/ack", "destination": "/api/ack" },
    { "source": "/nack", "destination": "/api/nack" },
    { "source": "/tick", "destination": "/api/tick" },
    { "source": "/login", "destination": "/api/dashboard" },
    { "source": "/logout", "destination": "/api/dashboard" },
    { "source": "/studio", "destination": "/api/dashboard" },
    { "source": "/dashboard", "destination": "/api/dashboard" },
    { "source": "/dashboard/:path*", "destination": "/api/dashboard" }
  ]
}
