<div class="card">
  <div style="display:flex; align-items:center; gap:14px;">
    <button class="toggle{% if p.enabled %} on{% endif %}" title="{% if p.enabled %}Disable{% else %}Enable{% endif %}"
            hx-post="/dashboard/plugins/toggle?id={{ p.encoded }}"
            hx-target="closest .card" hx-swap="outerHTML">
      <span class="knob"></span>
    </button>
    <span class="mono" style="font-size:13px;{% unless p.enabled %} color:var(--ink-muted);{% endunless %}">{{ p.id }}</span>
    <span class="chip{% unless p.enabled %} off{% endunless %}">{% if p.enabled %}Enabled{% else %}Off{% endif %}</span>
    <span class="mono" style="margin-left:auto; font-size:12px; color:{% if p.lastRunRed %}var(--red){% else %}var(--ink-muted){% endif %};">{{ p.lastRunText }}</span>
  </div>
  <form class="card-detail cfg{% unless p.enabled %} dim{% endunless %}"
        hx-post="/dashboard/plugins/config?id={{ p.encoded }}"
        hx-trigger="change" hx-target="closest .card" hx-swap="outerHTML">
    <span class="cfg-label">interval</span>
    <span class="cfg-value"><input class="editable" name="intervalSeconds" value="{{ p.intervalSeconds }}" size="5">s</span>
    {% for f in p.fields %}
    <span class="cfg-label">{{ f.label }}</span>
    {% if f.multiline %}
    <textarea class="editable cfg-area" name="cfg_{{ f.key }}" rows="{{ f.rows }}"
              spellcheck="false" placeholder="one per line">{{ f.value }}</textarea>
    {% else %}
    <span class="cfg-value"><input class="editable{% if f.wide %} cfg-wide{% endif %}" name="cfg_{{ f.key }}"
           value="{{ f.value }}" spellcheck="false"{% unless f.wide %} size="14"{% endunless %}></span>
    {% endif %}
    {% endfor %}
    <span class="cfg-label">templates</span>
    <span class="cfg-value mono" style="font-size:12px">{{ p.templates }}</span>
    {% if p.error %}<div class="field-error cfg-span">{{ p.error }}</div>{% endif %}
  </form>
</div>
