<div class="card">
  <div style="display:flex; align-items:center; gap:14px;">
    <button class="toggle{% if p.enabled %} on{% endif %}" title="{% if p.enabled %}Disable{% else %}Enable{% endif %}"
            hx-post="/dashboard/plugins/toggle?id={{ p.encoded }}"
            hx-target="closest .card" hx-swap="outerHTML">
      <span class="knob"></span>
    </button>
    <span class="mono" style="font-size:13px;{% unless p.enabled %} color:var(--ink-muted);{% endunless %}">{{ p.id }}</span>
    <span class="chip{% unless p.enabled %} off{% endunless %}">{% if p.enabled %}Enabled{% else %}Off{% endif %}</span>
    <span class="mono" style="margin-left:auto; font-size:12px; color:{% if p.lastRunRed %}var(--red){% else %}var(--ink-muted){% endif %};">{{ p.lastRunText }}</span>
  </div>
  <form class="card-detail" hx-post="/dashboard/plugins/config?id={{ p.encoded }}"
        hx-trigger="change" hx-target="closest .card" hx-swap="outerHTML">
    <span{% unless p.enabled %} style="color:var(--ink-faint)"{% endunless %}>interval
      <input class="editable" name="intervalSeconds" value="{{ p.intervalSeconds }}" size="4">s</span>
    <span{% unless p.enabled %} style="color:var(--ink-faint)"{% endunless %}>config
      <input class="editable" name="config" value="{{ p.configJson }}" size="34" spellcheck="false"></span>
    <span{% unless p.enabled %} style="color:var(--ink-faint)"{% endunless %}>templates
      <span class="mono" style="font-size:12px">{{ p.templates }}</span></span>
    {% if p.error %}<div class="field-error">{{ p.error }}</div>{% endif %}
  </form>
</div>
