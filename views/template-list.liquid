<div class="tpl-grid" id="template-list">
  {% for row in rows %}
  <div class="tpl-card">
    <a class="tpl-preview" href="/studio?template={{ row.encoded }}" title="Open in studio">
      <img src="/dashboard/templates/thumb?name={{ row.encoded }}" loading="lazy" alt="">
    </a>
    <div class="body">
      <div class="head">
        <a class="name" href="/studio?template={{ row.encoded }}">{{ row.name }}</a>
        <button class="icon-btn-row" title="Delete"
                hx-delete="/dashboard/templates?name={{ row.encoded }}"
                hx-confirm="Delete “{{ row.name }}”?"
                hx-target="#template-list" hx-swap="outerHTML">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
        </button>
      </div>
      <div class="sub">{{ row.usedBy }}{% if row.editedAgo != '—' %} · {{ row.editedAgo }}{% endif %}</div>
    </div>
  </div>
  {% else %}
  <div class="list" style="grid-column:1/-1"><div class="empty">No templates yet — create one to get started</div></div>
  {% endfor %}
</div>
