<div class="title-row">
  <div>
    <h1>Plugins</h1>
    <div class="subtitle">run by /tick when enabled and due</div>
  </div>
  <button class="btn" disabled title="Plugins are registered in code — see plugins/index.js">Register plugin</button>
</div>

{% for p in plugins %}
{% render 'plugin-card', p: p %}
{% else %}
<div class="list"><div class="empty">No plugins registered — they appear after the first tick</div></div>
{% endfor %}
