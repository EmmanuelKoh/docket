<div class="row-detail">
  <div class="cols">
    <div class="col" style="flex:0 0 200px">
      <div class="label">Printed</div>
      <img src="/jobs?png={{ job.id }}" alt="" loading="lazy"
           style="display:block; width:100%; margin-top:8px; background:#fff; border:0.5px solid var(--border); border-radius:2px;">
    </div>
    <div class="col">
      <div class="label">Template</div>
      <pre>{{ job.template }}</pre>
    </div>
    <div class="col">
      <div class="label">Data</div>
      <pre>{{ job.dataJson }}</pre>
    </div>
  </div>
  <div class="actions">
    <button class="btn small" hx-post="/dashboard/jobs/reprint?job={{ job.id }}"
            hx-target="this" hx-swap="outerHTML">Reprint</button>
  </div>
</div>
