<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} · DOCKET</title>
<link rel="stylesheet" href="/docket.css">
<script>
  (function () {
    if (localStorage.getItem('docket-theme') === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  })();
</script>
<script src="https://unpkg.com/htmx.org@1.9.12"></script>
</head>
<body>
<header class="header">
  <a class="wordmark" href="/dashboard">DOCKET</a>
  <nav class="nav">
    <a href="/dashboard"{% if active == 'home' %} class="active"{% endif %}>Home</a>
    <a href="/dashboard/templates"{% if active == 'templates' %} class="active"{% endif %}>Templates</a>
    <a href="/dashboard/photo"{% if active == 'photo' %} class="active"{% endif %}>Photo</a>
    <a href="/dashboard/plugins"{% if active == 'plugins' %} class="active"{% endif %}>Plugins</a>
    <a href="/dashboard/queue"{% if active == 'queue' %} class="active"{% endif %}>Queue</a>
    <a href="/dashboard/history"{% if active == 'history' %} class="active"{% endif %}>History</a>
    <button class="icon-btn" id="theme-toggle" title="Theme" aria-label="Toggle theme">
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
    </button>
    <a class="icon-btn" href="/logout" title="Sign out" aria-label="Sign out">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
    </a>
  </nav>
</header>
<main class="page">
{{ content | raw }}
</main>
<script>
  document.getElementById('theme-toggle').addEventListener('click', function () {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (dark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('docket-theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('docket-theme', 'dark');
    }
  });

  // Hover peek: readable receipt preview beside dense list thumbnails.
  var peek = document.createElement('div');
  peek.id = 'peek';
  peek.appendChild(document.createElement('img'));
  document.body.appendChild(peek);
  document.addEventListener('mouseover', function (e) {
    var thumb = e.target.closest('img.thumb');
    if (!thumb) return;
    var rect = thumb.getBoundingClientRect();
    peek.firstChild.src = thumb.src;
    peek.style.left = Math.min(rect.right + 12, window.innerWidth - 300) + 'px';
    peek.style.top = Math.max(12, Math.min(rect.top - 20, window.innerHeight * 0.28)) + 'px';
    peek.style.display = 'block';
  });
  document.addEventListener('mouseout', function (e) {
    if (e.target.closest && e.target.closest('img.thumb')) peek.style.display = 'none';
  });

  // History row expand/collapse (chevron rows carry data-slot + data-detail-url).
  document.addEventListener('click', function (e) {
    var row = e.target.closest('.row-expand');
    if (!row || e.target.closest('button, a, form, input, select')) return;
    var slot = document.getElementById(row.dataset.slot);
    if (!slot) return;
    if (slot.innerHTML.trim()) {
      slot.innerHTML = '';
      row.classList.remove('open');
    } else {
      htmx.ajax('GET', row.dataset.detailUrl, { target: '#' + row.dataset.slot, swap: 'innerHTML' });
      row.classList.add('open');
    }
  });
</script>
</body>
</html>
