<div class="title-row">
  <div>
    <h1>History</h1>
    <div class="subtitle">{{ total }} job{% unless total == 1 %}s{% endunless %} · newest first</div>
  </div>
  <span class="right">
    <select class="filter-select" onchange="location.href='/dashboard/history?filter='+this.value">
      <option value="all"{% if filter == 'all' %} selected{% endif %}>all</option>
      <option value="done"{% if filter == 'done' %} selected{% endif %}>done</option>
      <option value="failed"{% if filter == 'failed' %} selected{% endif %}>failed</option>
      <option value="canceled"{% if filter == 'canceled' %} selected{% endif %}>canceled</option>
    </select>
  </span>
</div>

{% if rows.size > 0 %}
<div class="list">
  {% for row in rows %}
  <div class="item">
    <div class="row row-expand" data-slot="slot-{{ row.id }}" data-detail-url="/dashboard/fragments/history-detail?job={{ row.id }}">
      <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ink-faint)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      <img class="thumb" src="{{ row.thumbUrl }}" loading="lazy" alt="">
      <div class="grow">
        <div class="name">{{ row.name }}</div>
        <div class="sub">{{ row.sub }}</div>
      </div>
      <div class="rail"><span class="status {{ row.statusClass }}">{{ row.statusText }}</span> · {{ row.railTime }}</div>
    </div>
    <div class="detail-slot" id="slot-{{ row.id }}"></div>
  </div>
  {% endfor %}
</div>
{% else %}
<div class="list"><div class="empty">Nothing here yet — finished jobs land in History</div></div>
{% endif %}

{% if pages > 1 %}
<div class="pagination">
  {% if page > 1 %}<a href="/dashboard/history?filter={{ filter }}&page={{ page | minus: 1 }}">← newer</a>{% else %}<span class="off">← newer</span>{% endif %}
  <span class="mono">{{ page }} / {{ pages }}</span>
  {% if page < pages %}<a href="/dashboard/history?filter={{ filter }}&page={{ page | plus: 1 }}">older →</a>{% else %}<span class="off">older →</span>{% endif %}
</div>
{% endif %}
