[
  {
    "name": "WC Kickoff",
    "template": "<div style=\"display:flex;flex-direction:column;width:576px;font-family:Sans;background:#fff;color:#000;padding:24px\">\n  <div style=\"display:flex;justify-content:center;background:#000;color:#fff;font-size:22px;font-weight:700;padding:6px\">KICK-OFF</div>\n  <div style=\"display:flex;flex-direction:column;align-items:center;margin-top:16px\">\n    <div style=\"display:flex;font-size:40px;font-weight:700\">{{ home }}</div>\n    <div style=\"display:flex;font-size:20px;margin:4px 0\">vs</div>\n    <div style=\"display:flex;font-size:40px;font-weight:700\">{{ away }}</div>\n  </div>\n  <div style=\"display:flex;border-top:3px dashed #000;margin-top:18px;padding-top:10px;flex-direction:column;font-family:Mono;font-size:17px\">\n    <div style=\"display:flex\">{{ competition }}</div>\n    <div style=\"display:flex\">{{ venue }}</div>\n    <div style=\"display:flex\">{{ kickoffTime }}</div>\n  </div>\n</div>",
    "data": {
      "home": "Portugal",
      "away": "Uzbekistan",
      "competition": "FIFA World Cup, Group K",
      "venue": "NRG Stadium, Houston",
      "kickoffTime": "1:00 PM ET"
    }
  },
  {
    "name": "WC Goal",
    "template": "<div style=\"display:flex;flex-direction:column;width:576px;font-family:Sans;background:#fff;color:#000;padding:24px\">\n  <div style=\"display:flex;justify-content:center;background:#000;color:#fff;font-size:48px;font-weight:700;padding:6px\">GOAL!</div>\n  <div style=\"display:flex;justify-content:center;font-size:26px;font-weight:700;margin-top:14px\">{{ scoringTeam }}</div>\n  <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:16px;font-family:Mono\">\n    <div style=\"display:flex;flex-direction:column;align-items:center;flex:1\">\n      <div style=\"display:flex;font-size:22px\">{{ home }}</div>\n      <div style=\"display:flex;font-size:56px;font-weight:700\">{{ homeScore }}</div>\n    </div>\n    <div style=\"display:flex;font-size:30px\">-</div>\n    <div style=\"display:flex;flex-direction:column;align-items:center;flex:1\">\n      <div style=\"display:flex;font-size:22px\">{{ away }}</div>\n      <div style=\"display:flex;font-size:56px;font-weight:700\">{{ awayScore }}</div>\n    </div>\n  </div>\n  <div style=\"display:flex;justify-content:center;border-top:3px dashed #000;margin-top:16px;padding-top:8px;font-family:Mono;font-size:18px\">{% if scorer %}{{ scorer }} {% endif %}{{ minute }}</div>\n  {% if assist %}<div style=\"display:flex;justify-content:center;font-family:Mono;font-size:15px;color:#555\">assist: {{ assist }}</div>{% endif %}\n</div>",
    "data": {
      "scoringTeam": "Portugal",
      "home": "Portugal",
      "away": "Uzbekistan",
      "homeScore": "1",
      "awayScore": "0",
      "scorer": "Cristiano Ronaldo",
      "assist": "João Cancelo",
      "minute": "6'"
    }
  },
  {
    "name": "WC Full Time",
    "template": "<div style=\"display:flex;flex-direction:column;width:576px;font-family:Sans;background:#fff;color:#000;padding:24px\">\n  <div style=\"display:flex;justify-content:center;background:#000;color:#fff;font-size:24px;font-weight:700;padding:6px\">FULL TIME</div>\n  <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:18px;font-family:Mono\">\n    <div style=\"display:flex;flex-direction:column;align-items:center;flex:1\">\n      <div style=\"display:flex;font-size:24px;font-weight:700\">{{ home }}</div>\n      <div style=\"display:flex;font-size:60px;font-weight:700\">{{ homeScore }}</div>\n    </div>\n    <div style=\"display:flex;font-size:30px\">-</div>\n    <div style=\"display:flex;flex-direction:column;align-items:center;flex:1\">\n      <div style=\"display:flex;font-size:24px;font-weight:700\">{{ away }}</div>\n      <div style=\"display:flex;font-size:60px;font-weight:700\">{{ awayScore }}</div>\n    </div>\n  </div>\n  <div style=\"display:flex;justify-content:center;background:#aaa;margin-top:18px;padding:10px;font-size:24px;font-weight:700\">{{ result }}</div>\n</div>",
    "data": {
      "home": "Portugal",
      "away": "Uzbekistan",
      "homeScore": "5",
      "awayScore": "0",
      "result": "Portugal win"
    }
  }
]
