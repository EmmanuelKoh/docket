// secrets.h.example — copy this file to secrets.h (same folder) and fill in
// real values. secrets.h is gitignored; NEVER put real credentials in any
// committed file — this repo is public.

#pragma once

#define SECRET_WIFI_SSID    "your-wifi-name"      // 2.4GHz network
#define SECRET_WIFI_PASS    "your-wifi-password"

// Local dev:  "http://192.168.1.20:3000"   (laptop running npm start)
// Production: "https://your-app.vercel.app"
#define SECRET_SERVER_URL   "http://192.168.1.20:3000"

// Must match the server's DEVICE_TOKEN (.env locally, Vercel env hosted).
#define SECRET_DEVICE_TOKEN "dev-token"
