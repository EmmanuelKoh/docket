// secrets.h.example — copy this file to secrets.h (same folder) and fill in
// real values. secrets.h is gitignored; NEVER put real credentials in any
// committed file — this repo is public.

#pragma once

#define SECRET_WIFI_SSID    "your-wifi-name"      // 2.4GHz network
#define SECRET_WIFI_PASS    "your-wifi-password"

// Local dev:  "http://192.168.1.20:3000"   (laptop running npm start)
// Production: "https://your-app.vercel.app"
#define SECRET_SERVER_URL   "http://192.168.1.20:3000"

// Optional. Leave "" for the pairing flow: on first boot the device
// prints a short code, you enter it on the dashboard's Printer page, and
// the minted per-device token is stored in flash (survives reboots and
// re-flashes that don't erase NVS). Setting a value here skips pairing —
// it must then match the server's legacy DEVICE_TOKEN (.env locally,
// Vercel env hosted); useful against a local dev server.
#define SECRET_DEVICE_TOKEN ""
